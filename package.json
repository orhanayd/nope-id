{
	"name": "nope-id",
	"version": "1.3.0",
	"description": "A tiny, fast, secure, URL-friendly unique string ID generator. ESM & CommonJS. Nanoid alternative with extra features (prefixed IDs, sortable IDs, UUID, distributed IDs).",
	"type": "module",
	"main": "index.cjs",
	"module": "index.js",
	"types": "index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./index.d.ts",
				"default": "./index.js"
			},
			"require": {
				"types": "./index.d.ts",
				"default": "./index.cjs"
			},
			"browser": "./index.browser.js"
		},
		"./non-secure": {
			"import": {
				"types": "./index.d.ts",
				"default": "./non-secure/index.js"
			},
			"require": {
				"types": "./index.d.ts",
				"default": "./non-secure/index.cjs"
			},
			"browser": "./non-secure/index.js"
		},
		"./package.json": "./package.json"
	},
	"browser": {
		"./index.js": "./index.browser.js",
		"./index.cjs": "./index.browser.js"
	},
	"react-native": {
		"./index.js": "./index.browser.js",
		"./index.cjs": "./index.browser.js"
	},
	"sideEffects": false,
	"engines": {
		"node": ">=16.0.0"
	},
	"scripts": {
		"test": "node tests/index.js",
		"test:core": "node tests/core.test.js",
		"test:features": "node tests/features.test.js",
		"test:utils": "node tests/utils.test.js",
		"test:non-secure": "node tests/non-secure.test.js",
		"test:idtypes": "node tests/idtypes.test.js",
		"test:encoding": "node tests/encoding.test.js",
		"test:secure-token": "node tests/secure-token.test.js",
		"test:ordered-id": "node tests/ordered-id.test.js",
		"test:randomness": "node tests/randomness.test.js",
		"test:types": "tsc --noEmit --strict --target es2022 --module nodenext --moduleResolution nodenext --allowImportingTsExtensions false tests/types.test.ts",
		"test:browser": "node tests/browser.test.js",
		"test:all": "npm test && npm run test:randomness && npm run test:types && npm run test:browser",
		"benchmark": "node benchmarks/benchmark.js",
		"benchmark:json": "node benchmarks/benchmark.js --json",
		"benchmark:vs-sparkid": "node benchmarks/orderedid-vs-sparkid.bench.js",
		"benchmark:update-readme": "node benchmarks/benchmark.js --json > bench.json && node scripts/update-readme.js bench.json && rm bench.json"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/orhanayd/nope-id.git"
	},
	"keywords": [
		"uuid",
		"id",
		"random",
		"unique",
		"generator",
		"nanoid",
		"secure",
		"url-safe",
		"crypto",
		"identifier",
		"sortable",
		"prefixed"
	],
	"author": "orhanayd",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/orhanayd/nope-id/issues"
	},
	"homepage": "https://github.com/orhanayd/nope-id#readme",
	"files": [
		"index.js",
		"index.cjs",
		"index.browser.js",
		"index.d.ts",
		"non-secure",
		"CHANGELOG.txt"
	],
	"devDependencies": {
		"@lukeed/uuid": "^2.0.1",
		"@paralleldrive/cuid2": "^3.3.0",
		"nanoid": "^5.1.11",
		"rndm": "^1.2.0",
		"secure-random-string": "^1.1.4",
		"sparkid": "^2.2.1",
		"typescript": "^5.9.3",
		"uid": "^2.0.2",
		"ulid": "^3.0.2",
		"uuid": "^14.0.0"
	},
	"maintainers": [
		{
			"name": "Orhan AYDOGDU",
			"email": "orhan.aydogdu@kentkart.com.tr"
		}
	]
}
